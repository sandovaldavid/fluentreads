---
import WhatsAppIcon from '../components/icons/WhatsApp.astro';
import SocialMediaButton from '../components/SocialMediaButton.astro';
import MobileIcon from '../components/icons/Mobile.astro';
import Navbar from '../components/Navbar.astro';
const logoImage = '/assets/logo_v4.webp';

import { siteConfig } from '@config/site';
import siteInfo from '../database/pageInformation.json';
---

<header className="bg-primary sticky top-0 z-50 w-full text-white shadow-md">
  <div
    className="container mx-auto flex flex-wrap items-center justify-between px-4 py-3 md:justify-center lg:justify-between"
  >
    <!-- Logo -->
    <a href="/" className="flex items-center lg:pl-8">
      <img src={logoImage} alt="FluentReads" className="size-12 rounded-full" />
      <span className="font-lora ml-2 text-2xl font-bold md:text-3xl">{siteConfig.name}</span>
    </a>

    <!-- Mobile menu button -->
    <button id="mobile-menu-button" className="flex items-center px-3 py-2 md:hidden">
      <MobileIcon class="h-6 w-6" />
    </button>

    <!-- Navigation and social icons -->
    <div
      id="menu"
      className="mobile-menu max-h-0 w-full flex-col overflow-hidden opacity-0 transition-all duration-300 ease-in-out md:mt-0 md:flex md:max-h-none md:w-auto md:opacity-100"
    >
      <Navbar />
    </div>
  </div>
</header>

<!-- Floating WhatsApp Button -->
<SocialMediaButton
  network="WhatsApp"
  href={siteConfig.whatsappUrl}
  class="bg-accent hover:bg-accent-dark fixed right-2 bottom-5 z-50 rounded-full p-3 text-white shadow-lg transition-colors md:right-6 md:bottom-8"
>
  <WhatsAppIcon class="size-8" />
</SocialMediaButton>

<script>
  // Mobile menu toggle functionality with animations
  document.addEventListener('DOMContentLoaded', () => {
    const mobileMenuButton = document.getElementById('mobile-menu-button');
    const menu = document.getElementById('menu');

    // Function to open the menu with animation
    const openMenu = () => {
      menu?.classList.add('menu-open');
      menu?.classList.remove('max-h-0', 'opacity-0');
      menu?.classList.add('max-h-[500px]', 'opacity-100');
    };

    // Function to close the menu with animation
    const closeMenu = () => {
      menu?.classList.remove('menu-open');
      menu?.classList.remove('max-h-[500px]', 'opacity-100');
      menu?.classList.add('max-h-0', 'opacity-0');
    };

    // Toggle menu function
    const toggleMenu = () => {
      if (menu?.classList.contains('menu-open')) {
        closeMenu();
      } else {
        openMenu();
      }
    };

    mobileMenuButton?.addEventListener('click', toggleMenu);

    // Handle window resize to ensure menu works correctly when switching between mobile and desktop
    window.addEventListener('resize', () => {
      if (window.innerWidth >= 768) {
        menu?.classList.remove('max-h-0', 'opacity-0');
        menu?.classList.add('max-h-[500px]', 'opacity-100');
      } else if (!menu?.classList.contains('menu-open')) {
        menu?.classList.remove('max-h-[500px]', 'opacity-100');
        menu?.classList.add('max-h-0', 'opacity-0');
      }
    });
  });
</script>
