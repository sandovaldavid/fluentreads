---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<span
  class={`cart-indicator bg-accent hidden inline-flex h-5 w-5 items-center justify-center rounded-full text-xs font-bold text-white ${className}`}
>
  0
</span>

<script>
  import { CartManager } from '../utils/cartManager';

  document.addEventListener('DOMContentLoaded', () => {
    // Update all cart indicators
    function updateCartIndicators() {
      const totalItems = CartManager.getItemCount();

      document.querySelectorAll('.cart-indicator').forEach((indicator) => {
        indicator.textContent = totalItems.toString();

        if (totalItems > 0) {
          indicator.classList.remove('hidden');
        } else {
          indicator.classList.add('hidden');
        }
      });
    }

    // Do initial update
    updateCartIndicators();

    // Set up event listener for cart changes
    window.addEventListener('cartUpdated', () => {
      updateCartIndicators();
    });
  });
</script>
