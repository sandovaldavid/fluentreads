---
interface OfferReference {
  id: string;
  type: 'book' | 'pack' | 'exam';
  expiration?: string;
  customLink?: string;
}

interface Offer {
  id: string;
  title: string;
  description: string;
  image: string;
  discount?: string;
  expiration?: string;
  link: string;
  type: 'book' | 'pack' | 'exam';
}

interface Props {
  title: string;
  subtitle?: string;
  ctaText?: string;
  ctaLink?: string;
  showCarousel?: boolean;
  maxOffersToShow?: number;
}

const {
  title,
  subtitle = 'Tu fuente principal de recursos para aprender inglés',
  ctaText = 'Explorar Catálogo',
  ctaLink = '/catalogo',
  showCarousel = true,
  maxOffersToShow = 4,
} = Astro.props;

// Import references from offerHeroBanner.json
import offerReferences from '../database/offerHeroBanner.json';
// Import source data files
import booksData from '../database/books.json';
import packsData from '../database/packs.json';
import examsData from '../database/exams.json';

// Function to get product details based on type and ID
function getProductDetails(reference: OfferReference): Offer | null {
  let product;

  switch (reference.type) {
    case 'book':
      product = booksData.find((book) => book.id === reference.id);
      if (product) {
        return {
          id: product.id,
          title: product.title,
          description: product.description,
          image: product.coverImage,
          discount: product.discount ? `${product.discount}%` : undefined,
          expiration: reference.expiration,
          link: reference.customLink || product.detailsLink,
          type: 'book',
        };
      }
      break;

    case 'pack':
      product = packsData.find((pack) => pack.id === reference.id);
      if (product) {
        return {
          id: product.id,
          title: product.title,
          description: product.description,
          image: product.coverImage,
          discount: product.discount ? `${product.discount}%` : undefined,
          expiration: reference.expiration,
          link: reference.customLink || product.detailsLink,
          type: 'pack',
        };
      }
      break;

    case 'exam':
      product = examsData.find((exam) => exam.id === reference.id);
      if (product) {
        return {
          id: product.id,
          title: product.title,
          description: product.description,
          image: product.coverImage,
          discount: product.discount ? `${product.discount}%` : undefined,
          expiration: reference.expiration,
          link: reference.customLink || product.detailsLink,
          type: 'exam',
        };
      }
      break;
  }

  return null;
}

// Process offer references to get complete offer data
const offerReferencesLimited = offerReferences.slice(0, maxOffersToShow);
const offers: Offer[] = offerReferencesLimited
  .map((ref) => getProductDetails(ref as OfferReference))
  .filter((offer): offer is Offer => offer !== null);

import { fade } from 'astro:transitions';
import '../styles/HeroBanner.css';
import ArrowRightIcon from './icons/ArrowRight.astro';
import CarouselButtons from './CarouselButtons.astro';
import Button from './Button.astro';
---

<section
  className="hero-banner bg-primary-dark relative overflow-hidden py-6 text-white md:py-18 lg:px-8 lg:py-10"
>
  <!-- Animated particles background effect -->
  <div className="particles-background absolute inset-0 opacity-20"></div>

  <div className="relative z-10 container mx-auto mt-6 px-4">
    <div className="mx-auto mb-12 max-w-5xl text-center">
      <h1
        className="animate-title mb-6 text-4xl font-bold md:text-6xl"
        transition:animate={fade({ duration: '0.8s' })}
      >
        {title}
      </h1>
      <p
        className="text-secondary-light animate-subtitle mb-10 text-xl md:text-2xl"
        transition:animate={fade({ duration: '0.8s' })}
      >
        {subtitle}
      </p>
      <Button
        href={ctaLink}
        variant="secondary"
        size="large"
        class="text-primary-dark animate-button-bounce font-extrabold"
      >
        {ctaText}
        <ArrowRightIcon class="animate-arrow ml-2 h-5 w-5" />
      </Button>
    </div>

    {
      showCarousel && offers.length > 0 && (
        <div className="offers-carousel mt-12 relative" data-offers-count={offers.length}>
          <div className="carousel-container overflow-hidden rounded-xl shadow-2xl">
            <div className="carousel-track flex transition-transform duration-500">
              {offers.map((offer, index) => (
                <div
                  className="carousel-slide w-full flex-shrink-0 p-6 md:p-8 bg-gradient-to-r from-primary to-primary-light rounded-xl overflow-hidden relative"
                  data-offer-id={offer.id}
                  data-offer-type={offer.type}
                >
                  <div className="flex flex-col md:flex-row items-center gap-8">
                    <div className="md:w-2/5 relative">
                      {offer.discount && (
                        <div className="absolute -top-2 -left-2 bg-accent text-white px-4 py-1 rounded-lg font-bold z-20 hero-pulse">
                          {offer.discount}
                        </div>
                      )}
                      <div className="absolute -top-2 -right-2 bg-primary-light text-white px-3 py-1 rounded-lg font-bold z-20">
                        {offer.type === 'book'
                          ? 'Libro'
                          : offer.type === 'pack'
                            ? 'Pack'
                            : 'Examen'}
                      </div>
                      <img
                        src={offer.image}
                        alt={offer.title}
                        className="rounded-lg shadow-lg object-cover w-full h-60 md:h-80 transform transition-transform hover:scale-105"
                        loading={index === 0 ? 'eager' : 'lazy'}
                      />
                    </div>
                    <div className="md:w-3/5 text-left">
                      <h3 className="text-2xl md:text-3xl font-bold mb-4 text-secondary">
                        {offer.title}
                      </h3>
                      <p className="text-lg md:text-xl mb-6">{offer.description}</p>
                      <div className="flex flex-col md:flex-row gap-4 items-start md:items-center">
                        <Button
                          variant="accent"
                          size="medium"
                          href={offer.link}
                          class="animate-button-slide"
                        >
                          <span>Ver detalles</span>
                          <ArrowRightIcon class="animate-arrow ml-2 h-5 w-5" />
                        </Button>
                        {offer.expiration && (
                          <p className="text-sm opacity-80">Expira: {offer.expiration}</p>
                        )}
                      </div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          {/* Carousel controls with proper aria labels */}
          <CarouselButtons
            ariaLabelPrev="Ver oferta anterior"
            ariaLabelNext="Ver oferta siguiente"
            className="carousel-buttons"
          />

          {/* Carousel indicators */}
          <div class="carousel-indicators mt-6 flex justify-center gap-2">
            {offers.map((_, index) => (
              <button
                class={`indicator-dot h-3 w-3 rounded-full ${index === 0 ? 'bg-secondary' : 'bg-gray-400'} hover:bg-secondary focus-visible:ring-secondary cursor-pointer transition-colors duration-300 focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-2`}
                data-index={index}
                aria-label={`Ver oferta ${index + 1}`}
              />
            ))}
          </div>
        </div>
      )
    }
  </div>
</section>

<script src="../scripts/HeroBanner.ts"></script>
