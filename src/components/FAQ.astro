---
import SectionTitle from './SectionTitle.astro';
import QuestionCard from './QuestionCard.astro';

import '../styles/FAQ.css';

// Import FAQ data directly
import generalFaqs from '../data/general-faqs.json';
import paymentFaqs from '../data/payment-faqs.json';
import catalogFaqs from '../data/catalog-faqs.json';

interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  jsonPath?: string; // Keep for backward compatibility but not used anymore
  dataset?: 'general' | 'payment' | 'catalog' | 'custom';
  customFAQs?: FAQItem[];
  title: string;
  description?: string;
  contactLink?: string;
  contactText?: string;
  class?: string;
  expanded?: number;
}

const {
  dataset = 'general',
  customFAQs = [],
  title,
  description = '',
  contactLink = '/contacto',
  contactText = 'Contáctanos directamente',
  class: className = '',
  expanded = -1,
} = Astro.props;

// Determine which FAQ dataset to use
let faqItems: FAQItem[] = [];
if (dataset === 'general') {
  faqItems = generalFaqs;
} else if (dataset === 'payment') {
  faqItems = paymentFaqs;
} else if (dataset === 'catalog') {
  faqItems = catalogFaqs;
} else if (dataset === 'custom' && customFAQs.length > 0) {
  faqItems = customFAQs;
}
---

<section class={`bg-neutral-light faq-section relative overflow-hidden ${className}`}>
  <!-- Decorative elements -->
  <div class="bg-primary/5 absolute top-0 right-0 -mt-32 -mr-32 h-64 w-64 rounded-full blur-3xl">
  </div>
  <div
    class="bg-secondary/5 absolute bottom-0 left-0 -mb-32 -ml-32 h-64 w-64 rounded-full blur-3xl"
  >
  </div>

  <div class="container mx-auto px-4">
    <div class="mx-auto max-w-4xl">
      <div class="mb-8 text-center md:mb-12">
        <SectionTitle>{title}</SectionTitle>
        {description && <p class="mx-auto mt-4 max-w-2xl text-gray-600">{description}</p>}
      </div>

      <div class="faq-container space-y-4 md:space-y-6">
        {
          faqItems.length > 0 ? (
            faqItems.map((item, index) => (
              <QuestionCard
                question={item.question}
                answer={item.answer}
                expanded={index === expanded}
                id={`faq-${title.replace(/\s+/g, '-').toLowerCase()}-${index}`}
              />
            ))
          ) : (
            <p class="border-neutral rounded-lg border bg-white p-8 text-center">
              No se encontraron preguntas frecuentes para mostrar.
            </p>
          )
        }
      </div>

      <!-- Additional support info -->
      <div class="border-neutral mt-10 rounded-xl border bg-white p-5 text-center shadow-sm">
        <p class="text-gray-700">
          ¿No encuentras respuesta a tu pregunta?
          <a
            href={contactLink}
            class="text-primary hover:text-primary-dark font-medium underline decoration-2 underline-offset-2"
          >
            {contactText}
          </a> y te responderemos a la brevedad.
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  // Add entrance animations
  document.addEventListener('DOMContentLoaded', () => {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            // Add staggered animation to cards
            const cards = entry.target.querySelectorAll('.question-card');
            cards.forEach((card, index) => {
              setTimeout(() => {
                card.classList.add('fade-in-visible');
              }, index * 100);
            });
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1 }
    );

    // Observe the FAQ container
    const faqContainer = document.querySelector('.faq-container');
    if (faqContainer) {
      observer.observe(faqContainer);
    }
  });
</script>
