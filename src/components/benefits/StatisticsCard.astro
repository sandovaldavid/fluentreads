---
import '../../styles/benefits/statisticsCard.css';
import StarIcon from '../icons/Star.astro';

// Stats for customer satisfaction section
const stats = {
  customers: '5,000+',
  books: '10,000+',
  satisfaction: '98%',
};

const { class: className = '' } = Astro.props;
---

<div
  class={`bg-primary text-white rounded-xl shadow-lg p-2 sm:p-4 stats-container transform transition-all duration-500 hover:shadow-xl ${className}`}
>
  <h3 class="mb-2 flex items-center text-lg font-bold sm:mb-4 sm:text-xl">
    <span class="text-primary shine-effect mr-3 rounded-full bg-white p-1">
      <StarIcon class="h-5 w-5" />
    </span>
    Clientes satisfechos
  </h3>

  <!-- Statistics -->
  <div class="flex flex-col p-4 lg:p-6">
    <!-- Stats Cards -->
    <div class="xs:grid-cols-3 mb-2 grid grid-cols-1 gap-3 sm:gap-6 lg:mb-6 lg:grid-cols-3">
      <div
        class="stat-item bg-primary-dark/30 hover:bg-primary-dark/40 transform rounded-lg p-2 transition-all duration-300 hover:scale-105 sm:p-4"
      >
        <div class="text-center">
          <div class="text-secondary counter-animation mb-1 text-xl font-bold sm:mb-2 md:text-2xl">
            {stats.customers}
          </div>
          <div class="text-xs text-white/90 sm:text-sm">Clientes Satisfechos</div>
        </div>
      </div>

      <div
        class="stat-item bg-primary-dark/30 hover:bg-primary-dark/40 transform rounded-lg p-1 transition-all duration-300 hover:scale-105 sm:p-2"
      >
        <div class="text-center">
          <div class="text-secondary counter-animation mb-1 text-xl font-bold sm:mb-2 md:text-2xl">
            {stats.books}
          </div>
          <div class="text-xs text-white/90 sm:text-sm">Libros Vendidos</div>
        </div>
      </div>

      <div
        class="stat-item bg-primary-dark/30 hover:bg-primary-dark/40 transform rounded-lg p-1 transition-all duration-300 hover:scale-105 sm:p-2"
      >
        <div class="text-center">
          <div class="text-secondary counter-animation mb-1 text-xl font-bold sm:mb-2 md:text-2xl">
            {stats.satisfaction}
          </div>
          <div class="text-xs text-white/90 sm:text-sm">Satisfacción</div>
        </div>
      </div>
    </div>

    <!-- Trust Banner -->
    <div
      class="bg-primary-dark/50 hover:bg-primary-dark/60 trust-banner transform rounded-lg p-2 text-justify shadow-md transition-all duration-300 hover:shadow-lg sm:p-3"
    >
      <p class="pt-1 text-center text-xs text-white/90 sm:text-sm md:text-base">
        Únete a miles de estudiantes y profesionales que confían en nosotros para su formación en
        inglés.
      </p>

      <div class="star-rating mt-2 flex justify-center space-x-1 sm:mt-3 sm:space-x-2">
        <span class="shine-effect text-sm text-yellow-400 sm:text-base md:text-lg">★</span>
        <span class="shine-effect text-sm text-yellow-400 sm:text-base md:text-lg">★</span>
        <span class="shine-effect text-sm text-yellow-400 sm:text-base md:text-lg">★</span>
        <span class="shine-effect text-sm text-yellow-400 sm:text-base md:text-lg">★</span>
        <span class="shine-effect text-sm text-yellow-400 sm:text-base md:text-lg">★</span>
      </div>
    </div>
  </div>
</div>
