---
import SelectBooksIcon from '../icons/SelectBooks.astro';
import PaymentIcon from '../icons/Payment.astro';
import InstantAccessIcon from '../icons/InstantAccess.astro';
import ArrowBottomIcon from '../icons/ArrowBottom.astro';
import CartIcon from '../icons/Cart.astro';
import ArrowRightIcon from '../icons/ArrowRight.astro';

import Button from '../Button.astro';
import '../../styles/benefits/purchaseStepsCard.css';

// Define purchase steps
const purchaseSteps = [
  {
    number: '01',
    icon: SelectBooksIcon,
    title: 'Elige tu pack de libros',
    description: 'Explora nuestros packs y selecciona el que más te interese.',
  },
  {
    number: '02',
    icon: PaymentIcon,
    title: 'Realiza el pago',
    description:
      'Paga con Yape, Plin, transferencia bancaria o PayPal. Envíanos el comprobante de pago por WhatsApp o Telegram.',
  },
  {
    number: '03',
    icon: InstantAccessIcon,
    title: 'Recibe tu material al instante',
    description: 'Te enviamos acceso inmediato a los libros en Google Drive / OneDrive.',
  },
];

const { className = '' } = Astro.props;
---

<div class={className}>
  <div
    className="h-ful steps-container h-full transform rounded-xl bg-white p-4 shadow-lg transition-all duration-500 hover:shadow-xl sm:p-6 md:p-8"
  >
    <h3 className="text-primary-dark mb-5 flex items-center text-xl font-bold md:mb-8 md:text-2xl">
      <span className="bg-secondary step-icon-header mr-3 rounded-full p-2 text-black">
        <CartIcon class="h-6 w-6" />
      </span>
      Guía de compra en 3 pasos
    </h3>

    <!-- Purchase steps -->
    <div className="steps-list relative mx-auto space-y-8 sm:space-y-10 lg:w-3/4">
      <!-- Step connector line -->
      <div
        className="absolute top-2 bottom-2 left-6 hidden w-0.5 bg-gray-200 sm:left-7 sm:block md:hidden"
      >
      </div>

      {
        purchaseSteps.map((step, index) => (
          <div className={`step-container group benefit-item benefit-item-${index + 1}`}>
            <div className="flex flex-col sm:flex-row items-center sm:items-start relative">
              <div className="step-icon-container mb-4 sm:mb-0 flex-shrink-0 relative z-10">
                {/* Numbered circle with improved visibility */}
                <div className="step-number bg-primary text-white text-lg font-bold rounded-full w-12 h-12 sm:w-14 sm:h-14 flex items-center justify-center shadow-md group-hover:bg-primary-dark transition-colors duration-300">
                  {step.number}
                </div>
                {/* Icon with hover effect */}
                <div className="step-icon text-primary h-12 w-12 sm:h-14 sm:w-14 my-3 mx-auto transform transition-transform duration-300 group-hover:scale-110">
                  <step.icon />
                </div>
              </div>

              {/* Content with better padding and hover effects */}
              <div className="ml-0 text-center sm:text-left step-content sm:p-4 sm:rounded-lg sm:-ml-2 transition-all duration-300">
                <h4 className="font-bold text-primary-dark text-lg sm:text-xl mb-2 group-hover:text-primary transition-colors duration-300">
                  {step.title}
                </h4>
                <p className="text-gray-600 text-sm sm:text-base max-w-sm">{step.description}</p>
              </div>

              {/* Next step indicator (except for last item) */}
              {index < purchaseSteps.length - 1 && (
                <ArrowBottomIcon class="text-primary-dark absolute top-30 left-4 hidden h-10 w-6 sm:left-4 lg:block" />
              )}
            </div>
          </div>
        ))
      }
    </div>

    <div className="cta-container text-center">
      <Button
        variant="primary"
        size="large"
        href="/paymentMethods"
        class="pulse-animation transform shadow-lg transition-all duration-300 hover:-translate-y-1 hover:scale-105 hover:shadow-xl"
      >
        <span className="flex items-center">
          <span>Métodos de Pago</span>
          <ArrowRightIcon class="ml-2 h-6 w-6" />
        </span>
      </Button>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Observer for purchase steps with staggered animation
    const stepsObserver = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) {
          const steps = document.querySelectorAll('.steps-list .step-container');
          steps.forEach((step, index) => {
            // Add slight delay between each step appearing
            setTimeout(() => {
              step.classList.add('visible');
            }, 150 * index);
          });
          stepsObserver.unobserve(entries[0].target);
        }
      },
      { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
    );

    // Observe the steps list container
    const stepsList = document.querySelector('.steps-list');
    if (stepsList) {
      stepsObserver.observe(stepsList);
    }
  });
</script>
