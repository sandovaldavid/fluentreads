---
import EmailIcon from './icons/Email.astro';
import BookIcon from './icons/Book.astro';
import HandshakeIcon from './icons/Handshake.astro';
import CTABackground from './icons/background/CTA.astro';
interface Props {
  title?: string;
  subtitle?: string;
  buttonText?: string;
  buttonLink?: string;
  className?: string;
  type?: 'default' | 'newsletter' | 'consultation';
}

const {
  title = 'Impulsa tu carrera con el inglés que necesitas',
  subtitle = 'No esperes más para empezar a mejorar tu inglés con nuestros materiales de alta calidad',
  buttonText = 'Explorar materiales',
  buttonLink = '/catalogo',
  className = '',
  type = 'default',
} = Astro.props;

// Different CTA types
const ctaConfig = {
  default: {
    title: title,
    subtitle: subtitle,
    buttonText: buttonText,
    buttonLink: buttonLink,
    bgClass: 'bg-gradient-to-r from-primary to-primary-dark',
    icon: 'BookIcon',
  },
  newsletter: {
    title: 'Mantente actualizado con nuestras novedades',
    subtitle: 'Suscríbete a nuestro boletín para recibir ofertas exclusivas y nuevos materiales',
    buttonText: 'Suscribirme',
    buttonLink: '#newsletter-form',
    bgClass: 'bg-gradient-to-r from-accent-dark to-accent',
    icon: 'EmailIcon',
  },
  consultation: {
    title: '¿Necesitas asesoramiento personalizado?',
    subtitle:
      'Nuestros especialistas pueden ayudarte a encontrar los materiales perfectos para tus necesidades',
    buttonText: 'Solicitar consulta',
    buttonLink: '/contacto',
    bgClass: 'bg-gradient-to-r from-secondary-dark to-secondary',
    icon: 'HandshakeIcon',
  },
};

const currentCta = ctaConfig[type];
---

<div className={`cta-banner ${currentCta.bgClass} rounded-xl overflow-hidden shadow-xl ${className}`}>
  <div className="relative container mx-auto px-6 py-10">
    <!-- Background decoration -->
    <CTABackground class="absolute top-0 right-0 h-64 w-64 text-amber-50 opacity-10" />
    <div className="relative z-10 flex flex-col items-center justify-between md:flex-row">
      <!-- Left Content -->
      <div className="mb-6 text-center text-white md:mr-6 md:mb-0 md:text-left">
        {
          type === 'newsletter' ? (
            <EmailIcon class="mb-4 h-10 w-10 md:h-15 md:w-15" />
          ) : type === 'consultation' ? (
            <HandshakeIcon class="mb-4 h-16 w-16 md:h-20 md:w-20" />
          ) : (
            <BookIcon class="mb-4 h-10 w-10 md:h-15 md:w-15" />
          )
        }
        <h3 className="mb-2 text-2xl font-bold md:text-3xl">
          {currentCta.title}
        </h3>
        <p className="max-w-xl text-white/90">{currentCta.subtitle}</p>
      </div>

      <!-- Right Content -->
      <div className="flex-shrink-0">
        {
          type === 'newsletter' ? (
            <form id="newsletter-form" className="flex flex-col items-center gap-3 sm:flex-row">
              <input
                type="email"
                placeholder="Tu correo electrónico"
                className="rounded-lg border-2 border-white/30 bg-white/10 px-4 py-3 text-white placeholder:text-white/70 focus:border-white focus:outline-none"
                required
              />
              <button
                type="submit"
                className="text-primary-dark hover:bg-neutral-light rounded-lg bg-white px-6 py-3 font-bold shadow-md transition-colors"
              >
                {currentCta.buttonText}
              </button>
            </form>
          ) : (
            <a
              href={currentCta.buttonLink}
              className="text-primary-dark hover:bg-neutral-light inline-block rounded-lg bg-white px-6 py-3 font-bold shadow-md transition-colors"
            >
              {currentCta.buttonText}
            </a>
          )
        }
      </div>
    </div>
  </div>
</div>

<script>
  // Newsletter form handling
  document.addEventListener('DOMContentLoaded', () => {
    const newsletterForm = document.getElementById('newsletter-form');
    if (newsletterForm) {
      newsletterForm.addEventListener('submit', (e) => {
        e.preventDefault();
        const emailInput = newsletterForm.querySelector('input[type="email"]');
        if (emailInput) {
          const email = (emailInput as HTMLInputElement).value;
          alert(`¡Gracias por suscribirte con ${email}! Pronto recibirás nuestras novedades.`);
          (emailInput as HTMLInputElement).value = '';
        }
      });
    }
  });
</script>
