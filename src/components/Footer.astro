---
import SocialMediaContent from './SocialMediaContent.astro';
import Button from './Button.astro';
import '../styles/Footer.css';
import { siteConfig } from '@config/site';

const currentYear = new Date().getFullYear();
const footerLinks = [
  {
    title: 'Navegación',
    links: [
      { text: 'Inicio', url: '/' },
      { text: 'Catálogo', url: '/catalogo' },
      { text: 'Testimonios', url: '/testimonios' },
      { text: 'Contacto', url: '/contacto' },
    ],
  },
  {
    title: 'Categorías',
    links: [
      { text: 'Inglés para Negocios', url: '/catalogo/negocios' },
      { text: 'Inglés Profesional', url: '/catalogo/profesional' },
      { text: 'Gramática & Vocabulario', url: '/catalogo/gramatica' },
      { text: 'Certificaciones', url: '/catalogo/certificaciones' },
      { text: 'Materiales Didácticos', url: '/catalogo/didacticos' },
    ],
  },
  {
    title: 'Ayuda',
    links: [
      { text: 'Preguntas Frecuentes', url: '/ayuda/faq' },
      { text: 'Soporte', url: '/contacto' },
    ],
  },
];
---

<footer className="bg-primary px-4 pt-8 pb-6 text-white md:px-8 md:pt-12">
  <div className="container mx-auto px-4">
    <!-- Top Section with Logo, Newsletter and Social Media -->
    <div className="mb-6 grid grid-cols-1 gap-6 md:mb-10 md:grid-cols-2 md:gap-10 lg:grid-cols-3">
      <!-- Logo and Description -->
      <div className="flex flex-col">
        <a href="/" className="text-secondary mb-3 text-2xl font-bold md:mb-4">FluentReads</a>
        <p className="text-neutral-light mb-4 max-w-md text-sm md:mb-6 md:text-base">
          Tu fuente confiable de libros en inglés y materiales educativos para profesionales y
          estudiantes que buscan dominar el idioma inglés.
        </p>
        <!-- Social Media Icons -->
        <div className="mt-2 md:mt-4">
          <SocialMediaContent
            showFacebook={true}
            showInstagram={true}
            showTwitter={true}
            showWhatsApp={true}
            facebookUrl={siteConfig.social.facebook}
            instagramUrl={siteConfig.social.instagram}
            twitterUrl={siteConfig.social.twitter}
            whatsAppUrl={siteConfig.whatsappUrl}
            class="flex justify-center space-x-4 sm:justify-start"
            iconSize="h-6 w-6"
          />
        </div>
      </div>

      <!-- Newsletter Signup -->
      <div className="mt-2 md:mt-0 lg:col-span-2">
        <div className="bg-primary-dark rounded-lg p-4 shadow-inner md:p-8">
          <h3 className="text-secondary mb-2 text-lg font-semibold md:mb-3 md:text-2xl">
            ¡Suscríbete a nuestro boletín!
          </h3>
          <p className="text-neutral-light mb-4 text-sm md:mb-6 md:text-base">
            Recibe ofertas exclusivas, novedades editoriales y consejos para mejorar tu inglés.
          </p>
          <form className="flex flex-col gap-3 sm:flex-row">
            <input
              type="email"
              placeholder="Tu correo electrónico"
              className="focus:ring-secondary bg-primary-light flex-grow rounded-full px-4 py-2 text-sm text-white focus:ring-2 focus:outline-none md:py-3 md:text-base"
              required
            />
            <Button
              variant="secondary"
              type="submit"
              size="small"
              class="md:size-medium transform whitespace-nowrap shadow-md transition-all duration-300 hover:shadow-lg"
            >
              Suscribirse
            </Button>
          </form>
          <p className="text-neutral-light mt-2 text-xs md:mt-3">
            Al suscribirte, aceptas nuestra <a
              href="/politica-privacidad"
              className="hover:text-secondary underline">política de privacidad</a
            >.
          </p>
        </div>
      </div>
    </div>

    <!-- Middle Section with Links -->
    <div
      className="border-primary-light grid grid-cols-2 gap-4 border-t border-b py-6 sm:grid-cols-2 md:grid-cols-3 md:gap-8 md:py-8"
    >
      {
        footerLinks.map((section) => (
          <div className="mb-2 md:mb-0">
            <h4 className="text-secondary mb-2 text-base font-semibold md:mb-4 md:text-lg">
              {section.title}
            </h4>
            <ul className="space-y-1 md:space-y-2">
              {section.links.map((link) => (
                <li>
                  <a
                    href={link.url}
                    className="text-neutral-light hover:text-secondary inline-block py-1 text-sm transition-colors duration-200 md:text-base"
                  >
                    {link.text}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <!-- Bottom Section with Copyright -->
    <div className="text-neutral-light mt-6 text-center text-xs md:mt-8 md:text-sm">
      <p>© {currentYear} FluentReads. Todos los derechos reservados.</p>
    </div>
  </div>
</footer>
