---
import Button from '../Button.astro';
import WhatsAppIcon from '../icons/WhatsApp.astro';
import ArrowRightIcon from '../icons/ArrowRight.astro';
import '../../styles/paymentMethods/CTA.css';
import DollarIcon from '../icons/Dollar.astro';
import SecurityIcon from '../icons/Security.astro';
import ClockIcon from '../icons/Clock.astro';
import CardIcon from '../icons/Card.astro';
import TrustIndicator from '../TrustIndicator.astro';
import TestimoniesCard from '../TestimoniesCard.astro';
import { siteConfig } from '@config/site';
---

<section className="bg-primary cta-payment-container relative overflow-hidden py-16 text-white">
  <!-- Animated background elements -->
  <div className="cta-animated-bg"></div>

  <!-- Decorative circles -->
  <div className="cta-circle cta-circle-1"></div>
  <div className="cta-circle cta-circle-2"></div>
  <div className="cta-circle cta-circle-3"></div>

  <div className="relative z-10 container mx-auto px-4 text-center md:px-8">
    <div className="mx-auto max-w-5xl">
      <div className="cta-payment-icon">
        <span className="cta-icon-pulse">
          <DollarIcon class="h-10 w-10" />
        </span>
      </div>

      <h2 className="cta-title mb-6 text-3xl font-bold md:text-4xl">
        ¿Listo para mejorar tu inglés?
      </h2>

      <!-- Fixed horizontal stars -->
      <div className="mb-6 flex items-center justify-center gap-1">
        <div className="stars-container">
          <span className="star">★</span>
          <span className="star">★</span>
          <span className="star">★</span>
          <span className="star">★</span>
          <span className="star">★</span>
        </div>
        <span className="rating-count">(+2,500 clientes satisfechos)</span>
      </div>

      <p className="mx-auto mb-8 max-w-3xl text-lg leading-relaxed opacity-90 md:text-xl">
        Elige el material que necesitas, realiza el pago y comienza a aprender hoy mismo. <span
          className="highlight pulse-text">¡Tu futuro profesional te espera!</span
        >
      </p>

      <!-- Trust badges with improved layout -->
      <div className="trust-badges-container">
        <div className="trust-badge">
          <div className="badge-icon">
            <SecurityIcon class="h-7 w-7" />
          </div>
          <span>Pago 100% Seguro</span>
        </div>
        <div className="trust-badge">
          <div className="badge-icon">
            <ClockIcon class="h-7 w-7" />
          </div>
          <span>Entrega Inmediata</span>
        </div>
        <div className="trust-badge">
          <div className="badge-icon">
            <CardIcon class="h-7 w-7" />
          </div>
          <span>Múltiples Métodos de Pago</span>
        </div>
      </div>

      <!-- Enhanced countdown timer -->
      <div className="countdown-container">
        <div className="countdown-header">
          <span className="flash-icon">⚡</span> Oferta especial termina en:
        </div>
        <div className="countdown-display">
          <div className="countdown-unit">
            <div className="countdown-value" id="hours">24</div>
            <div className="countdown-label">Horas</div>
          </div>
          <div className="countdown-separator">:</div>
          <div className="countdown-unit">
            <div className="countdown-value" id="minutes">00</div>
            <div className="countdown-label">Minutos</div>
          </div>
          <div className="countdown-separator">:</div>
          <div className="countdown-unit">
            <div className="countdown-value" id="seconds">00</div>
            <div className="countdown-label">Segundos</div>
          </div>
        </div>
      </div>

      <!-- Action buttons with better spacing and emphasis -->
      <div className="cta-action-buttons">
        <Button variant="secondary" size="large" href="/catalogo" class="primary-cta-button">
          <span className="flex items-center">
            Ver Catálogo
            <ArrowRightIcon class="bounce-right ml-2 h-5 w-5" />
          </span>
        </Button>
        <Button
          variant="accent"
          size="large"
          href={siteConfig.whatsappUrl}
          class="secondary-cta-button"
        >
          <WhatsAppIcon class="mr-2 h-5 w-5" />
          Contactar por WhatsApp
        </Button>
      </div>

      <!-- Enhanced testimonial -->
      <div className="animate-on-scroll lg:mx-auto lg:max-w-xl">
        <TestimoniesCard
          quote="FluentReads me ayudó a mejorar mi inglés de forma rápida y sencilla. ¡Lo recomiendo!"
          author="María Fernández"
          position="Estudiante de Medicina"
          avatarUrl="https://i.pravatar.cc/100?img=40"
          rating={4.5}
          compact
        />
      </div>

      <!-- Added satisfaction guarantee -->
      <div className="satisfaction-guarantee">
        <TrustIndicator />
        <p>100% Garantía de satisfacción o te devolvemos tu dinero</p>
      </div>
    </div>
  </div>
</section>

<script>
  // Countdown timer functionality
  document.addEventListener('DOMContentLoaded', () => {
    function updateCountdown() {
      let countdownEnd: string | null = null;
      try {
        countdownEnd = localStorage.getItem('countdownEnd');
      } catch (e) {
        // Silently handle localStorage access error
      }

      if (!countdownEnd) {
        // Set end time to 24 hours from now
        const end = new Date();
        end.setHours(end.getHours() + 24);
        try {
          localStorage.setItem('countdownEnd', end.getTime().toString());
        } catch (e) {
          // Silently handle localStorage set error
        }
      }

      let endTimeVal: string;
      try {
        endTimeVal = localStorage.getItem('countdownEnd') || '0';
      } catch (e) {
        // Fallback end time (24h from now in memory if localStorage fails)
        const fallbackEnd = new Date();
        fallbackEnd.setHours(fallbackEnd.getHours() + 24);
        endTimeVal = fallbackEnd.getTime().toString();
      }

      const endTime = parseInt(endTimeVal, 10);
      const now = new Date().getTime();
      const timeLeft = endTime - now;

      if (timeLeft <= 0) {
        // Reset the timer when it reaches zero
        try {
          localStorage.removeItem('countdownEnd');
        } catch (e) {
          // Silently handle localStorage remove error
        }
        updateCountdown();
        return;
      }

      // Calculate time units
      const hours = Math.floor(timeLeft / (1000 * 60 * 60));
      const minutes = Math.floor((timeLeft % (1000 * 60 * 60)) / (1000 * 60));
      const seconds = Math.floor((timeLeft % (1000 * 60)) / 1000);

      // Update the HTML safely without non-null assertions
      const hoursEl = document.getElementById('hours');
      const minutesEl = document.getElementById('minutes');
      const secondsEl = document.getElementById('seconds');

      if (hoursEl) hoursEl.textContent = hours.toString().padStart(2, '0');
      if (minutesEl) minutesEl.textContent = minutes.toString().padStart(2, '0');
      if (secondsEl) secondsEl.textContent = seconds.toString().padStart(2, '0');
    }

    // Update the countdown immediately and then every second
    updateCountdown();
    setInterval(updateCountdown, 1000);

    // Add entrance animations
    const animateElements = document.querySelectorAll('.animate-on-scroll');
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('animated');
            observer.unobserve(entry.target);
          }
        });
      },
      {
        threshold: 0.2,
      }
    );

    animateElements.forEach((el) => {
      observer.observe(el);
    });

    // Add pulse effect to CTA buttons
    const ctaButtons = document.querySelectorAll('.primary-cta-button');
    ctaButtons.forEach((button) => {
      button.classList.add('pulse-animation');
    });

    // Add stars animation
    const stars = document.querySelectorAll('.star');
    stars.forEach((star, index) => {
      setTimeout(() => {
        star.classList.add('star-animated');
      }, index * 150);
    });
  });
</script>
