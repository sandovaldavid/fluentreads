---
import Button from '../Button.astro';
import PayPalIcon from '../icons/payments/PayPal.astro';
import BcpIcon from '../icons/payments/Bcp.astro';
import BbvaIcon from '../icons/payments/Bbva.astro';
import Wave from '../icons/Wave.astro';
import ArrowBottomIcon from '../icons/ArrowBottom.astro';
import '../../styles/paymentMethods/Hero.css';

// Import payment method icons
const paymentIcons = [
  { Icon: BcpIcon, alt: 'BCP' },
  { Icon: BbvaIcon, alt: 'BBVA' },
  { Icon: PayPalIcon, alt: 'PayPal' },
];
---

<section
  className="from-primary to-primary-dark relative overflow-hidden bg-gradient-to-br py-16 text-white md:py-24"
>
  <!-- Decorative elements -->
  <div className="absolute top-0 left-0 h-full w-full overflow-hidden opacity-10">
    <div className="payment-circle payment-circle-1"></div>
    <div className="payment-circle payment-circle-2"></div>
    <div className="payment-circle payment-circle-3"></div>
  </div>

  <div className="relative z-10 container mx-auto px-4">
    <div className="mx-auto max-w-4xl text-center">
      <div className="animate-bounce-subtle mb-6 inline-block">
        <span
          className="bg-secondary text-primary-dark inline-flex items-center justify-center rounded-full p-3 shadow-lg"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-8 w-8"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"
            ></path>
          </svg>
        </span>
      </div>

      <h1 className="text-gradient mb-6 text-3xl font-bold md:text-4xl lg:text-5xl">
        ¿Cómo puedes pagar?
      </h1>

      <p className="mx-auto mb-8 max-w-3xl text-lg opacity-90 md:text-xl">
        En <span className="text-secondary font-semibold">FluentReads</span>
        te ofrecemos diferentes métodos de pago para facilitar tu compra. Elige el que mejor se adapte
        a tus necesidades.
      </p>

      <!-- Payment method icons preview -->
      <div className="payment-icons-container mb-8 flex items-center justify-center gap-4">
        {
          paymentIcons.map((item, index) => (
            <div
              className="transform rounded-full bg-white/40 p-3 backdrop-blur-sm transition-all duration-300 hover:scale-110 hover:bg-white/60"
              style={`animation-delay: ${index * 0.1}s`}
            >
              <item.Icon class="h-10 w-10 text-white" />
            </div>
          ))
        }
        <div
          className="flex h-10 w-10 items-center justify-center rounded-full bg-white/10 backdrop-blur-sm transition-all hover:bg-white/20"
        >
          <span className="font-bold text-white">+</span>
        </div>
      </div>

      <Button
        variant="secondary"
        size="large"
        href="#payment-methods"
        newTab={false}
        class="mb-12 transform shadow-lg transition hover:scale-105 hover:shadow-xl lg:mb-16"
      >
        Ver métodos de pago
        <ArrowBottomIcon class="ml-2 h-5 w-5" />
      </Button>
    </div>
  </div>

  <!-- Subtle wave pattern at bottom -->
  <div
    className="absolute bottom-0 left-0 w-full overflow-hidden leading-none"
    style="transform: rotate(180deg)"
  >
    <Wave class="relative block h-[60px] w-full" />
  </div>
</section>
