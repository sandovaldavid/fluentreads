---
import ClockIcon from '../icons/Clock.astro';

interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;

// Define business hours
const businessHours = {
  timezone: 'GMT-5',
  schedule: 'Lunes a Viernes: 9:00 AM - 6:00 PM | Sábados: 9:00 AM - 1:00 PM',
  responseTime: {
    whatsapp: 'Respuesta en WhatsApp: 30 min - 2 horas',
    email: 'Respuesta por correo: 24 horas máximo',
  },
};
---

<div className={`schedule-banner ${className}`}>
  <div
    className="from-primary/10 to-primary-light/5 border-primary-light/20 rounded-xl border bg-gradient-to-r p-5 lg:shadow-md lg:transition-all lg:duration-300 lg:hover:shadow-lg"
  >
    <div className="flex flex-col items-center gap-4 md:flex-row">
      <!-- Business Hours Content -->
      <div className="flex flex-1 flex-col space-y-3">
        <div className="mb-4 flex items-center">
          <span className="bg-primary mr-3 rounded-full p-2 text-white">
            <ClockIcon class="h-5 w-5" />
          </span>
          <h3 className="text-primary-dark text-lg font-bold md:text-xl lg:text-2xl">
            Horarios de Atención <span className="text-primary text-sm font-normal"
              >({businessHours.timezone})</span
            >
          </h3>
        </div>

        <div className="grid grid-cols-1 gap-3 md:grid-cols-2">
          <!-- Schedule -->
          <div className="border-neutral rounded-lg border bg-white/70 p-3 shadow-sm">
            <p className="text-sm font-medium text-gray-700">Horario de servicio</p>
            <p className="text-sm text-gray-600">
              {businessHours.schedule}
            </p>
          </div>

          <!-- Response Time -->
          <div className="border-neutral rounded-lg border bg-white/70 p-3 shadow-sm">
            <p className="text-sm font-medium text-gray-700">Tiempos de respuesta</p>
            <p className="text-accent-dark text-sm">
              {businessHours.responseTime.whatsapp}
            </p>
            <p className="text-primary text-sm">
              {businessHours.responseTime.email}
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .schedule-banner {
    animation: fadeIn 0.6s ease-in-out;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Pulse animation for the clock icon */
  @media (min-width: 768px) {
    .schedule-banner:hover :global(svg) {
      animation: pulse 1.5s infinite;
    }
  }

  @keyframes pulse {
    0% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.05);
    }
    100% {
      transform: scale(1);
    }
  }
</style>
