---
import EmailIcon from '../icons/Email.astro';
import WhatsAppIcon from '../icons/WhatsApp.astro';
import TelegramIcon from '../icons/Telegram.astro';
import SmartPhoneIcon from '../icons/SmartPhone.astro';
import Button from '../Button.astro';
import '../../styles/contact/contactInfo.css';

import { siteConfig } from '@config/site';

// Contact data
const contactData = {
  email: siteConfig.contact.email,
  whatsapp: siteConfig.whatsapp,
  telegram: siteConfig.social.telegram,
  supportHours: 'Lunes a Viernes: 9:00 AM - 6:00 PM | Sábados: 9:00 AM - 1:00 PM',
};
---

<section
  className="contact-info-section my-4 rounded-xl bg-white p-6 shadow-md transition-all duration-300 hover:shadow-lg md:my-8 md:p-8 lg:mx-10"
>
  <!-- Contact Methods Grid -->
  <div className="grid gap-6 md:grid-cols-2">
    <!-- Email Contact -->
    <div
      className="contact-method-card border-neutral hover:border-primary-light group rounded-lg border bg-white p-5 transition-all duration-300 hover:shadow-md"
    >
      <div className="flex flex-col items-center gap-4 md:flex-row">
        <div className="flex flex-1 flex-col space-y-3">
          <div className="mb-4 flex items-center">
            <span className="bg-primary mr-3 rounded-full p-2 text-white">
              <EmailIcon class="h-5 w-5" />
            </span>
            <h3 className="text-primary-dark text-lg font-bold md:text-xl lg:text-2xl">
              Correo Electrónico
            </h3>
          </div>
        </div>
      </div>

      <p className="mb-4 text-gray-600">
        Para consultas, soporte o cualquier información adicional, escríbenos a:
      </p>

      <a
        href={`mailto:${contactData.email}`}
        className="text-primary hover:text-primary-dark inline-flex items-center font-medium underline decoration-2 underline-offset-4 transition-colors duration-200"
      >
        {contactData.email}
      </a>
    </div>

    <!-- Direct Messaging -->
    <div
      className="contact-method-card border-neutral hover:border-primary-light rounded-lg border bg-white p-5 transition-all duration-300 hover:shadow-md"
    >
      <div className="flex flex-col items-center gap-4 md:flex-row">
        <div className="flex flex-1 flex-col space-y-3">
          <div className="mb-4 flex items-center">
            <span className="bg-primary mr-3 rounded-full p-2 text-white">
              <SmartPhoneIcon class="h-5 w-5" />
            </span>
            <h3 className="text-primary-dark text-lg font-bold md:text-xl lg:text-2xl">
              Mensajería Directa
            </h3>
          </div>
        </div>
      </div>
      <p className="mb-5 text-gray-600">
        Contacta con nuestro equipo de soporte instantáneo a través de:
      </p>

      <div className="flex flex-col gap-4 sm:flex-row">
        <Button
          variant="accent"
          href={`https://wa.me/${contactData.whatsapp}`}
          class="flex flex-1 items-center justify-center shadow-md hover:shadow-lg"
        >
          <WhatsAppIcon class="mr-2 h-5 w-5" />
          WhatsApp
        </Button>

        <Button
          variant="primary"
          href={`https://t.me/${contactData.telegram}`}
          class="flex flex-1 items-center justify-center shadow-md hover:shadow-lg"
        >
          <TelegramIcon class="mr-2 h-5 w-5" />
          Telegram
        </Button>
      </div>
    </div>
  </div>

  <!-- Trust Message -->
  <div className="bg-primary/5 border-primary/10 mt-8 rounded-lg border p-4 text-center">
    <p className="text-gray-600">
      Nos esforzamos por responder a todas las consultas lo más rápido posible, generalmente en
      menos de 24 horas durante días laborables.
    </p>
  </div>
</section>

<script>
  // Add entrance animations
  document.addEventListener('DOMContentLoaded', () => {
    const cards = document.querySelectorAll('.contact-method-card');

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('animated');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1 }
    );

    cards.forEach((card, index) => {
      // Add a small delay between each card animation
      setTimeout(() => {
        observer.observe(card);
      }, index * 150);
    });
  });
</script>
