---
import Layout from '../../../layouts/Layout.astro';
import SectionTitle from '../../../components/SectionTitle.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import CatalogExamContainer from '../../../components/catalog/CatalogExamContainer.astro';
import PromoSection from '../../../components/catalog/PromoSection.astro';
import FAQ from '../../../components/FAQ.astro';
import CTABanner from '../../../components/CTA-Banner.astro';
import CategoryCards from '../../../components/catalog/CategoryCards.astro';
import '../../../styles/catalog.css';

// Import data and proper types
import type { Exam } from '../../../types/exam';
import { ExamType, ExamDifficulty } from '../../../types/exam';
import { getProductsByType } from '../../../utils/listProducts';

// Get filter parameters from URL if any
const { searchParams } = Astro.url;
const difficulty = searchParams.get('difficulty') || 'all';
const examType = searchParams.get('examType') || 'all';
const sort = searchParams.get('sort') || 'featured';

// Define type-safe mapping objects
const difficultyNames: Record<string, string> = {
  [ExamDifficulty.BEGINNER]: 'Principiante',
  [ExamDifficulty.INTERMEDIATE]: 'Nivel Intermedio',
  [ExamDifficulty.ADVANCED]: 'Nivel Avanzado',
  [ExamDifficulty.UPPER_INTERMEDIATE]: 'Intermedio Alto',
  [ExamDifficulty.PROFICIENT]: 'Proficiente',
};

const examTypeNames: Record<string, string> = {
  [ExamType.IELTS]: 'IELTS',
  [ExamType.TOEFL]: 'TOEFL',
  [ExamType.CAMBRIDGE]: 'Cambridge',
  [ExamType.SAT]: 'SAT',
  [ExamType.PTE]: 'PTE',
  [ExamType.FCE]: 'FCE',
  [ExamType.CPE]: 'CPE',
  [ExamType.GRE]: 'GRE',
  [ExamType.OTHER]: 'Otros Exámenes',
};

// Determine page title and description based on filters
let pageTitle = 'Exámenes Internacionales de Inglés';
let pageDescription =
  'Prepárate para exámenes internacionales de inglés con nuestros materiales de estudio. Recursos para IELTS, TOEFL, Cambridge y más.';
let canonicalUrl = new URL('/catalogo/examenes-internacionales', Astro.site).toString();
let categoryHeroImage = '/images/book-sample/exam-hero.jpg';

// If difficulty filter is applied, customize title
if (difficulty !== 'all') {
  const difficultyName = difficultyNames[difficulty] || difficulty;
  pageTitle = `Exámenes de Inglés - ${difficultyName}`;
  pageDescription = `Materiales de preparación para exámenes internacionales de inglés de nivel ${difficultyName}. Recursos para certificar tu nivel.`;
  canonicalUrl = new URL(
    `/catalogo/examenes-internacionales?difficulty=${difficulty}`,
    Astro.site
  ).toString();
}

// If exam type filter is applied, customize further
if (examType !== 'all') {
  const examTypeName = examTypeNames[examType] || examType;
  pageTitle = `${examTypeName} - ${pageTitle}`;
  pageDescription = `Preparación para el examen ${examTypeName}. ${pageDescription}`;
  canonicalUrl = new URL(
    `/catalogo/examenes-internacionales?examType=${examType}`,
    Astro.site
  ).toString();
}

// Get exams data using the utility function
const allExams = getProductsByType('exam');

// Convert to Exam[] type and ensure all required fields exist
const safeExams: Exam[] = allExams.map((exam) => ({
  id: exam.id,
  title: exam.title,
  description: exam.description || '',
  price: exam.price,
  coverImage: exam.coverImage,
  altText: exam.altText || `${exam.title} Exam cover`,
  includedItems: (exam as any).includedItems || [],
  rating: exam.rating || { score: 0, reviewCount: 0 },
  buyLink: (exam as any).buyLink || `/checkout/${exam.id}`,
  detailsLink: exam.detailsLink || `/catalogo/examenes-internacionales/${exam.id}`,
  discount: exam.discount || 0,
  examType: (exam as any).examType || ExamType.OTHER,
  difficulty: (exam.level as ExamDifficulty) || ExamDifficulty.INTERMEDIATE,
  featured: exam.featured || false,
  formatTags: exam.formatTags || [],
  popularityTags: exam.popularityTags || [],
  images: (exam as any).images || [],
  video: (exam as any).video || '',
}));

// Define breadcrumb items
const breadcrumbItems = [
  { label: 'Inicio', url: '/' },
  { label: 'Catálogo', url: '/catalogo' },
  {
    label: 'Exámenes Internacionales',
    url: '/catalogo/examenes-internacionales',
    active: true,
  },
];

// Define structured data for SEO
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  hasPart: safeExams.map((exam) => ({
    '@type': 'Product',
    name: exam.title,
    description: exam.description,
    url: new URL(`/catalogo/examenes-internacionales/${exam.id}`, Astro.site).toString(),
    image: exam.coverImage,
    offers: {
      '@type': 'Offer',
      price: exam.discount ? exam.price * (1 - exam.discount / 100) : exam.price,
      priceCurrency: 'PEN',
      availability: 'https://schema.org/InStock',
    },
  })),
};
---

<Layout
  title={`${pageTitle} | FluentReads`}
  description={pageDescription}
  canonicalURL={canonicalUrl}
  structuredData={structuredData}
>
  <!-- Hero Banner -->
  <section
    className="catalog-hero bg-primary relative overflow-hidden bg-cover bg-center py-12 text-white"
    style={`background-image: linear-gradient(to bottom, rgba(30, 58, 138, 0.8), rgba(30, 58, 138, 0.5)), url(${categoryHeroImage});`}
  >
    <div className="from-primary-dark/80 to-primary/40 absolute inset-0 bg-gradient-to-r"></div>
    <div className="relative z-10 container mx-auto px-8">
      <div className="grid h-full grid-cols-1 gap-8 md:grid-cols-3">
        <!-- Text content -->
        <div className="text-center md:col-span-2 md:text-left">
          <!-- Breadcrumbs -->
          <Breadcrumb items={breadcrumbItems} class="mb-6 text-white/90" />
          <div>
            <div
              className="fade-in mb-4 inline-block rounded-lg bg-white/10 p-4 text-4xl shadow-lg backdrop-blur-sm"
            >
              🎓
            </div>
            <h1 className="slide-in-left mb-4 text-3xl font-bold md:text-4xl lg:text-5xl">
              Exámenes Internacionales de Inglés
            </h1>
            <p className="slide-in-left mb-6 max-w-2xl text-lg text-white/90 delay-100 md:text-xl">
              Material de preparación para certificaciones internacionales. Mejora tus resultados en
              IELTS, TOEFL, Cambridge y más con recursos completos y actualizados.
            </p>
            <div
              className="slide-in-left flex flex-wrap justify-center gap-4 delay-200 md:justify-start"
            >
              <a
                href="#catalog-section"
                className="bg-secondary hover:bg-secondary-dark text-primary-dark rounded-lg px-6 py-3 font-bold shadow-lg transition-all duration-300 hover:shadow-xl"
              >
                Ver Exámenes
              </a>
              <a
                href="#contact-form"
                className="rounded-lg bg-white/20 px-6 py-3 font-semibold text-white backdrop-blur-sm transition-all duration-300 hover:bg-white/30"
              >
                Consultar Disponibilidad
              </a>
            </div>
          </div>
        </div>

        <!-- Decorative element -->
        <div
          className="fade-in relative hidden items-center justify-center overflow-hidden rounded-lg border-4 border-white/20 shadow-2xl delay-300 md:flex"
        >
          <div
            className="from-primary/40 to-accent/30 flex aspect-[3/4] h-full w-full items-center justify-center bg-gradient-to-br backdrop-blur-sm"
          >
            <img
              src="/images/book-sample/exam-sample-01.jpg"
              alt="Muestra de material de examen internacional"
              className="h-full w-full object-cover"
            />
          </div>
        </div>
      </div>
    </div>

    <!-- Decorative shapes -->
    <div
      className="absolute right-0 -bottom-8 left-0 h-16 bg-white"
      style="clip-path: polygon(0 0, 100% 100%, 100% 100%, 0% 100%);"
    >
    </div>
    <div
      className="absolute right-0 -bottom-8 left-0 h-16 bg-white/20 backdrop-blur-sm"
      style="clip-path: polygon(0 0, 100% 100%, 100% 100%, 0% 100%);"
    >
    </div>
  </section>

  <!-- Main Catalog Section -->
  <section className="catalog-section relative py-12" id="catalog-section">
    <div className="catalog-pattern absolute inset-0 opacity-[0.03]"></div>
    <div className="relative z-10 container mx-auto px-4">
      <!-- Main catalog container component -->
      <CatalogExamContainer
        exams={safeExams}
        initialDifficulty={difficulty}
        initialExamType={examType}
        initialSort={sort}
        gridCols={4}
        productSize="medium"
      />
    </div>
  </section>

  <!-- Related Categories Section -->
  <section className="bg-neutral-light py-12">
    <div className="container mx-auto px-4">
      <div className="mb-10 text-center">
        <SectionTitle>Explora otras categorías</SectionTitle>
        <p className="mx-auto max-w-3xl text-gray-600">
          Descubre nuestra selección completa de materiales educativos en inglés
        </p>
      </div>
      <CategoryCards />
    </div>
  </section>

  <!-- Promotional Section -->
  <PromoSection
    title="Ofertas en Materiales de Preparación"
    subtitle="Ofertas Especiales"
    className="from-primary/5 to-accent/5 bg-gradient-to-br py-16"
    countdownDays={5}
    cardSize="large"
  />

  <!-- FAQ Section -->
  <FAQ
    className="py-16"
    dataset="catalog"
    title="Preguntas frecuentes sobre exámenes internacionales"
    description="Resuelve tus dudas sobre nuestros materiales de preparación para exámenes."
  />

  <!-- CTA Banner -->
  <div className="container mx-auto mb-16 px-4">
    <CTABanner type="default" />
  </div>
</Layout>

<style>
  .catalog-hero {
    background-position: center;
    background-size: cover;
    position: relative;
  }

  .catalog-pattern {
    background-image: url('/pattern.svg');
    opacity: 0.2;
  }

  .slide-in-left {
    animation: slideInLeft 0.8s ease forwards;
    opacity: 0;
    transform: translateX(-20px);
  }

  .delay-100 {
    animation-delay: 0.1s;
  }

  .delay-200 {
    animation-delay: 0.2s;
  }

  .delay-300 {
    animation-delay: 0.3s;
  }

  .fade-in {
    animation: fadeIn 1s ease forwards;
    opacity: 0;
  }

  @keyframes slideInLeft {
    from {
      opacity: 0;
      transform: translateX(-20px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Smooth scroll to sections when clicking navigation links
    document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
      anchor.addEventListener('click', function (this: HTMLAnchorElement, e) {
        e.preventDefault();
        const targetId = this.getAttribute('href');
        if (targetId) {
          const targetElement = document.querySelector(targetId);
          if (targetElement) {
            targetElement.scrollIntoView({
              behavior: 'smooth',
              block: 'start',
            });
          }
        }
      });
    });
  });
</script>
