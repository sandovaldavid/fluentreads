---
import Layout from '../../../layouts/Layout.astro';
import SectionTitle from '../../../components/SectionTitle.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import CatalogBookContainer from '../../../components/catalog/CatalogBookContainer.astro';
import PromoSection from '../../../components/catalog/PromoSection.astro';
import FAQ from '../../../components/FAQ.astro';
import CTABanner from '../../../components/CTA-Banner.astro';
import CategoryCards from '../../../components/catalog/CategoryCards.astro';
import '../../../styles/catalog.css';

// Import types, utilities and data
import type { Book } from '../../../types/book';
import { BookLevel, FormatTag, PopularityTag } from '../../../types/book';
import { getProductsByType } from '../../../utils/listProducts';
import editorialsData from '../../../database/editorial.json';

// Get filter parameters from URL if any
const { searchParams } = Astro.url;
const level = searchParams.get('level') || 'all';
const format = searchParams.get('format') || 'all';
const sort = searchParams.get('sort') || 'featured';

// Define type-safe mapping objects
const levelNames: Record<string, string> = {
  [BookLevel.BASIC]: 'Nivel Básico',
  [BookLevel.INTERMEDIATE]: 'Nivel Intermedio',
  [BookLevel.ADVANCED]: 'Nivel Avanzado',
  [BookLevel.PROFESSIONAL]: 'Nivel Profesional',
  [BookLevel.ALL_LEVELS]: 'Multi-nivel',
};

const formatNames: Record<string, string> = {
  [FormatTag.PDF]: 'PDF',
  [FormatTag.WORKBOOK]: 'Workbooks',
  [FormatTag.AUDIO]: 'Material con Audio',
  [FormatTag.VIDEO]: 'Material con Video',
  [FormatTag.SOFTWARE]: 'Software',
  [FormatTag.EXAMS]: 'Exámenes de Práctica',
};

// Determine page title and description based on filters
let pageTitle = 'Catálogo de Libros en Inglés';
let pageDescription =
  'Explora nuestra colección de libros en inglés para todos los niveles. Encuentra el material perfecto para mejorar tu inglés con nuestro amplio catálogo.';
let canonicalUrl = new URL('/catalogo/libros', Astro.site).toString();
let categoryHeroImage = '/images/book-sample/library-hero.jpg';

// If level filter is applied, customize title
if (level !== 'all') {
  const levelName = levelNames[level] || level;
  pageTitle = `Libros en Inglés - ${levelName}`;
  pageDescription = `Materiales educativos en inglés para ${levelName}. Encuentra los recursos perfectos para tu nivel de aprendizaje.`;
  canonicalUrl = new URL(`/catalogo/libros?level=${level}`, Astro.site).toString();
}

// If format filter is applied, customize further
if (format !== 'all') {
  const formatName = formatNames[format] || format;
  pageTitle = `${formatName} - ${pageTitle}`;
  pageDescription = `${formatName} ${pageDescription}`;
  canonicalUrl = new URL(`/catalogo/libros?format=${format}`, Astro.site).toString();
}

// Create editorial lookup map
const editorialMap = new Map<string, string>();
editorialsData.forEach((editorial) => {
  editorialMap.set(editorial.id, editorial.nombre);
});

// Get book data using the utility function
const allBooks = getProductsByType('book');

// Convert to Book[] type and ensure all required fields exist
const safeBooks: Book[] = allBooks.map((book) => ({
  id: book.id,
  title: book.title,
  description: book.description || '',
  price: book.price,
  editorialId: 'editorialId' in book ? (book.editorialId as string) : '',
  coverImage: book.coverImage,
  altText: book.altText || `${book.title} Book cover`,
  includedItems: 'includedItems' in book ? (book.includedItems as string[]) : [],
  rating: book.rating || { score: 0, reviewCount: 0 },
  buyLink: 'buyLink' in book ? (book.buyLink as string) : `/checkout/${book.id}`,
  detailsLink: book.detailsLink || `/catalogo/libros/${book.id}`,
  discount: book.discount || 0,
  level: (book.level as BookLevel) || BookLevel.INTERMEDIATE,
  featured: book.featured || false,
  formatTags: book.formatTags || [],
  popularityTags: book.popularityTags || [],
}));

// Define breadcrumb items
const breadcrumbItems = [
  { label: 'Inicio', url: '/' },
  { label: 'Catálogo', url: '/catalogo' },
  { label: 'Libros', url: '/catalogo/libros', active: true },
];

// Structured data for SEO
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  hasPart: safeBooks.map((book) => ({
    '@type': 'Book',
    name: book.title,
    description: book.description,
    url: new URL(`/catalogo/libros/${book.id}`, Astro.site).toString(),
    image: book.coverImage,
    offers: {
      '@type': 'Offer',
      price: book.discount ? book.price * (1 - book.discount / 100) : book.price,
      priceCurrency: 'PEN',
      availability: 'https://schema.org/InStock',
    },
  })),
};
---

<Layout
  title={`${pageTitle} | FluentReads`}
  description={pageDescription}
  canonicalURL={canonicalUrl}
  structuredData={structuredData}
>
  <!-- Hero Banner -->
  <section
    className="catalog-hero bg-primary relative overflow-hidden bg-cover bg-center py-12 text-white"
    style={`background-image: linear-gradient(to bottom, rgba(30, 58, 138, 0.8), rgba(30, 58, 138, 0.5)), url(${categoryHeroImage});`}
  >
    <div className="from-primary-dark/80 to-primary/40 absolute inset-0 bg-gradient-to-r"></div>
    <div className="relative z-10 container mx-auto px-8">
      <div className="grid h-full grid-cols-1 gap-8 md:grid-cols-3">
        <!-- Text content -->
        <div className="text-center md:col-span-2 md:text-left">
          <!-- Breadcrumbs -->
          <Breadcrumb items={breadcrumbItems} class="mb-6 text-white/90" />
          <div>
            <div
              className="fade-in mb-4 inline-block rounded-lg bg-white/10 p-4 text-4xl shadow-lg backdrop-blur-sm"
            >
              📚
            </div>
            <h1 className="slide-in-left mb-4 text-3xl font-bold md:text-4xl lg:text-5xl">
              Catálogo de Libros en Inglés
            </h1>
            <p className="slide-in-left mb-6 max-w-2xl text-lg text-white/90 delay-100 md:text-xl">
              Explora nuestra colección completa de libros en inglés para todos los niveles y
              formatos. Ofrecemos materiales educativos que te ayudarán a mejorar tu dominio del
              idioma.
            </p>
            <div
              className="slide-in-left flex flex-wrap justify-center gap-4 delay-200 md:justify-start"
            >
              <a
                href="#catalog-section"
                className="bg-secondary hover:bg-secondary-dark text-primary-dark rounded-lg px-6 py-3 font-bold shadow-lg transition-all duration-300 hover:shadow-xl"
              >
                Ver Catálogo
              </a>
              <a
                href="#contact-form"
                className="rounded-lg bg-white/20 px-6 py-3 font-semibold text-white backdrop-blur-sm transition-all duration-300 hover:bg-white/30"
              >
                Consultar Disponibilidad
              </a>
            </div>
          </div>
        </div>

        <!-- Decorative element -->
        <div
          className="fade-in relative hidden items-center justify-center overflow-hidden rounded-lg border-4 border-white/20 shadow-2xl delay-300 md:flex"
        >
          <div
            className="from-primary/40 to-accent/30 flex aspect-[3/4] h-full w-full items-center justify-center bg-gradient-to-br backdrop-blur-sm"
          >
            <img
              src="/images/book-sample/book-sample-01.jpg"
              alt="Muestra de libro de inglés"
              className="h-full w-full object-cover"
            />
          </div>
        </div>
      </div>
    </div>

    <!-- Decorative shapes -->
    <div
      className="absolute right-0 -bottom-8 left-0 h-16 bg-white"
      style="clip-path: polygon(0 0, 100% 100%, 100% 100%, 0% 100%);"
    >
    </div>
    <div
      className="absolute right-0 -bottom-8 left-0 h-16 bg-white/20 backdrop-blur-sm"
      style="clip-path: polygon(0 0, 100% 100%, 100% 100%, 0% 100%);"
    >
    </div>
  </section>

  <!-- Main Catalog Section -->
  <section className="catalog-section relative py-12" id="catalog-section">
    <div className="catalog-pattern absolute inset-0 opacity-[0.03]"></div>
    <div className="relative z-10 container mx-auto px-4">
      <!-- Main catalog container component -->
      <CatalogBookContainer
        books={safeBooks}
        initialLevel={level}
        initialFormat={format}
        initialSort={sort}
        editorialMap={editorialMap}
        gridCols={4}
        productSize="medium"
      />
    </div>
  </section>

  <!-- Related Categories Section -->
  <section className="bg-neutral-light py-12">
    <div className="container mx-auto px-4">
      <div className="mb-10 text-center">
        <SectionTitle>Explora otras categorías</SectionTitle>
        <p className="mx-auto max-w-3xl text-gray-600">
          Descubre nuestra selección completa de materiales educativos en inglés
        </p>
      </div>
      <CategoryCards />
    </div>
  </section>

  <!-- Promotional Section -->
  <PromoSection
    title="Ofertas y Promociones Exclusivas"
    subtitle="Ofertas Especiales"
    className="from-primary/5 to-accent/5 bg-gradient-to-br py-16"
    countdownDays={5}
    cardSize="large"
  />

  <!-- FAQ Section -->
  <FAQ
    className="py-16"
    dataset="catalog"
    title="Preguntas frecuentes sobre nuestros libros"
    description="Resolvemos tus dudas sobre nuestros materiales de inglés."
  />

  <!-- CTA Banner -->
  <div className="container mx-auto mb-16 px-4">
    <CTABanner type="default" />
  </div>
</Layout>

<style>
  .catalog-hero {
    background-position: center;
    background-size: cover;
    position: relative;
  }

  .catalog-pattern {
    background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.2'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  }

  .slide-in-left {
    animation: slideInLeft 0.8s ease forwards;
    opacity: 0;
    transform: translateX(-20px);
  }

  .delay-100 {
    animation-delay: 0.1s;
  }

  .delay-200 {
    animation-delay: 0.2s;
  }

  .delay-300 {
    animation-delay: 0.3s;
  }

  .fade-in {
    animation: fadeIn 1s ease forwards;
    opacity: 0;
  }

  @keyframes slideInLeft {
    from {
      opacity: 0;
      transform: translateX(-20px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Smooth scroll to sections when clicking navigation links
    document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
      anchor.addEventListener('click', function (this: HTMLAnchorElement, e) {
        e.preventDefault();
        const targetId = this.getAttribute('href');
        if (targetId) {
          const targetElement = document.querySelector(targetId);
          if (targetElement) {
            targetElement.scrollIntoView({
              behavior: 'smooth',
              block: 'start',
            });
          }
        }
      });
    });
  });
</script>
